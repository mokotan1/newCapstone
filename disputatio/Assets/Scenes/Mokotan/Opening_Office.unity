  indentLevel: 0
  storyText: "\uC81C\uAC00 \uACBD\uCC30\uC5D0 \uBA3C\uC800 \uC804\uD654\uB97C \uD588\uB294\uB370\uC694.
    \uB2E8\uC21C \uC545\uCDE8 \uC2E0\uACE0\uB9CC\uC73C\uB85C\uB294 \uC0AC\uC720\uC9C0\uB77C
    \uBC14\uB85C \uD655\uC778\uC774 \uC5B4\uB835\uACE0, \uC77C\uB2E8 \uC8FC\uBBFC\uC13C\uD130\uC5D0
    \uBA3C\uC800 \uBBFC\uC6D0\uC744 \uB123\uC5B4\uC57C \uC808\uCC28\uAC00 \uD6E8\uC52C
    \uBE60\uB974\uB2E4\uACE0 \uD558\uB354\uB77C\uACE0\uC694."
